/**
 * @file Firestore Security Rules for MekaTech.
 *
 * @Core Philosophy:
 *   This ruleset enforces a user-ownership model for clients and mechanics,
 *   combined with shared access based on denormalized IDs within job requests.
 *   It prioritizes authorization independence and structural segregation to
 *   simplify security rules and improve performance.
 *
 * @Data Structure:
 *   - /users/{userId}: Stores user profiles and roles. The source of truth for authorization.
 *   - /clients/{clientId}: Stores client profiles, accessible only by the client.
 *   - /mechanics/{mechanicId}: Stores mechanic profiles, accessible only by the mechanic. Admins can approve them.
 *   - /jobs/{jobId}: Stores job requests, accessible by the client who created the
 *     job and the assigned mechanic.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---

    function isSignedIn() {
      return request.auth != null;
    }
    
    // Checks if the 'role' field in the user's own profile document is 'admin'.
    // This is secure because the rule to *write* this document is protected.
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isJobOwner(clientId) {
      return isSignedIn() && request.auth.uid == clientId;
    }

    function isJobOwnerExisting(clientId) {
      return isJobOwner(clientId) && resource != null;
    }
    
    function isAssignedMechanic(mechanicId) {
      return isSignedIn() && request.auth.uid == mechanicId;
    }

    function isAssignedMechanicExisting(mechanicId) {
      return isAssignedMechanic(mechanicId) && resource != null;
    }

    /**
     * @description Controls access to user profiles and roles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      // A user can always read their own profile. An admin can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      // Only admins can list all users.
      allow list: if isAdmin();
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      // A user can update their own profile, but cannot change their role.
      // An admin can update any part of any profile.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      // Only admins can delete user profiles.
      allow delete: if isAdmin();
    }
    
    match /clients/{clientId} {
      allow get: if isOwner(clientId);
      allow list: if false; // Listing clients is not permitted.
      allow create: if isSignedIn() && isOwner(clientId) && request.resource.data.id == clientId;
      allow update: if isExistingOwner(clientId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(clientId);
    }

    match /mechanics/{mechanicId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow signed-in users to list mechanics.
      // Mechanic can create their own profile, but status must be 'Pending'
      allow create: if isOwner(mechanicId) && request.resource.data.status == 'Pending';
      
      // Mechanic can update their profile if they are the owner and not changing their status.
      // Admin can update any part of the profile (including changing status).
      allow update: if (isExistingOwner(mechanicId) && request.resource.data.status == resource.data.status) || isAdmin();
      
      allow delete: if isExistingOwner(mechanicId) || isAdmin();
    }

    match /jobs/{jobId} {
      allow get: if isJobOwner(resource.data.clientId) || isAssignedMechanic(resource.data.mechanicId) || isAdmin();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if (isAssignedMechanicExisting(resource.data.mechanicId) || isJobOwnerExisting(resource.data.clientId)) || isAdmin();
      allow delete: if isJobOwnerExisting(resource.data.clientId) || isAdmin();
    }
  }
}

